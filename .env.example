# Supabase (optional). If set, FinTrack will save and load data from your Supabase project.
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Scenario Lab AI — default is local Ollama via npm run server (see README).
# Use gemini to call Google Gemini from the browser instead.
# VITE_AI_PROVIDER=ollama
# VITE_AI_PROVIDER=gemini

# Google Gemini — only if VITE_AI_PROVIDER=gemini
# Get yours at: https://aistudio.google.com/app/apikey
# VITE_GEMINI_API_KEY=your-gemini-api-key

# Optional: override chat API base (production). Dev uses Vite proxy to localhost:3001.
# VITE_CHAT_API_URL=
# VITE_OLLAMA_MODEL=llama3.2
# VITE_CHAT_API_SECRET=

# Google OAuth – required for real Google Sign-In (optional; falls back to demo mode)
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised JavaScript origins (add both if you use either):
#   http://localhost:8080
#   http://127.0.0.1:8080
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server-side (node server/llm-chat-server.mjs) — not VITE_*
# CHAT_SERVER_PORT=3001
# CHAT_SERVER_HOST=127.0.0.1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_NUM_PREDICT=768
# CHAT_API_SECRET=
