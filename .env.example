# Google Gemini – Get a FREE key at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional). If set, FinTrack will save and load data from your Supabase project.
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override chat API base (production). Dev uses Vite proxy to localhost:3001.
# VITE_CHAT_API_URL=
# VITE_CHAT_API_SECRET=

# Google OAuth – required for real Google Sign-In (optional; falls back to demo mode)
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised JavaScript origins: http://localhost:8080 or http://127.0.0.1:8080
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
